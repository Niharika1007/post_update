{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "moduleResolution": "node",

    "typeRoots": ["./src/types", "./node_modules/@types"],

    "types": ["node"]
  },

  "include": ["src"]
}